{
  "name": "vulnra-scan-action",
  "version": "1.0.0",
  "description": "GitHub Action: run VULNRA LLM vulnerability scans in CI/CD pipelines.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build dist/index.js -o dist --source-map --license licenses.txt",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
