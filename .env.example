# ── VULNRA Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values
# Required vars are marked with (REQUIRED)

# ── Security (REQUIRED for local dev) ──────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-secret-change-me-local-only

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Find these at: https://supabase.com/dashboard → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Anthropic (for AI Judge - optional for local dev) ───────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Lemon Squeezy (for billing - optional for local dev) ────────────────────
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── Email (for Sentinel alerts - optional) ──────────────────────────────────
RESEND_API_KEY=your-resend-api-key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── App Settings ─────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8000
API_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
