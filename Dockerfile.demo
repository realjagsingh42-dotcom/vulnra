# ─────────────────────────────────────────────────────────────────────────────
# VULNRA Demo Vulnerable LLM Dockerfile
# Deliberately vulnerable LLM for testing the scanner
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt || true

# Install FastAPI for the demo
RUN pip install --no-cache-dir fastapi uvicorn

# Copy demo LLM
COPY demo/vulnerable_llm.py .

# Expose port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl --fail http://localhost:8001/health || exit 1

# Run the demo LLM
CMD ["python", "vulnerable_llm.py"]
